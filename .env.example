# Captura de leads — /api/visit-lead

# OBRIGATÓRIO: email pra Denise/Simone via Resend
RESEND_API_KEY=re_...                                # mesma key do Lumied
RESEND_FROM=Maple Bear Caxias <site@maplebearcaxiasdosul.com.br>
LEAD_NOTIFY_TO=denise@maplebearcaxiasdosul.com.br,simone@maplebearcaxiasdosul.com.br

# OPCIONAL: integração Lumied (cria lead no CRM da escola Caxias)
# Se ausente, o endpoint funciona só com Resend
LUMIED_API_URL=https://brgorknbrjlfwvrrlwxj.supabase.co/functions/v1/api
LUMIED_ANON_KEY=eyJhbGciOiJIUzI1NiI...               # supabase anon key (mesma do app Lumied)
LUMIED_ESCOLA_SLUG=maplebearcaxias                   # slug da escola, default já é maplebearcaxias

# OPCIONAL: trigger imediato da cadência drip "Boas-vindas" (D+0)
# Quando o lead é criado, /api/visit-lead chama crm-drip-send pra disparar
# o D+0 na hora em vez de esperar até 15min pelo pg_cron.
# Sem essas vars, o lead recebe o D+0 no próximo tick do cron drip-send.
DRIP_SEND_URL=https://brgorknbrjlfwvrrlwxj.supabase.co/functions/v1/crm-drip-send
DRIP_SEND_KEY=drip_caxias_5a41cc471600db1901d641dd0f09dd99
